        <mxCell id="e9" value="cred only" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#666666;" edge="1" parent="1" source="a9" target="a10">
          <mxGeometry relative="1" as="geometry" />
